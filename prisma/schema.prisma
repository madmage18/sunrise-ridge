enum ProductType {
  subscription 
  product
  ticket
  appointmentRequiredTicket
}

enum ProductCategory {
  dairy 
  eggs 
  flowers   
}

model Option {
  id          String  @id @default(cuid())
  farmId      String
  name        String
  priceChange Int
  // establish relationship between Option and Product models. Each option can be associated with multiple Product entities
  Product Product[]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id           String     @id @default(uuid())
  name        String
  company     String
  type        ProductType
  productCategory    ProductCategory
  experience Boolean
  shortDescription String
  description String
  featured   Boolean
  options Option[]
  siteSpecial   Boolean
  image       String
  price       Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  clerkId  String
  favorites Favorite[]
}

model Favorite {
  id        String   @id @default(uuid())
  clerkId  String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
